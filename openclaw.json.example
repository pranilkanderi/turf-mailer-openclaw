{
  "$schema": "https://docs.openclaw.ai/schema.json",
  "identity": {
    "name": "turfbot",
    "theme": "Turfproject AI Assistant",
    "emoji": "🌱"
  },
  "env": {
    "vars": {
      "GOOGLE_API_KEY": "",
      "TELEGRAM_BOT_TOKEN": "",
      "SIMPLYNOTED_API_KEY": "",
      "SIMPLYNOTED_USER_ID": "",
      "SIMPLYNOTED_SENDER_PROFILE_ID": ""
    }
  },
  "agents": {
    "defaults": {
      "workspace": "./workspace",
      "model": {
        "primary": "google/gemini-1.5-pro-latest",
        "fallback": "ollama/gemma4:26b"
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "",
      "dmPolicy": "open"
    }
  },
  "gateway": {
    "port": 18789
  }
}
